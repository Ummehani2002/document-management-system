APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the same scheme (http/https) and host you use in the browser. If you open the app via HTTPS
# but APP_URL is http://..., Chrome may block PDF downloads as "Insecure download blocked".
APP_URL=http://localhost
# Display/storage timezone for dates (UAE). Recent uploads and other timestamps use this.
APP_TIMEZONE=Asia/Dubai

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Microsoft Entra ID (Azure AD) sign-in + send shared files from the logged-in user's mailbox
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI="${APP_URL}/login/microsoft/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Upload limits (MB). Production must also raise nginx client_max_body_size and PHP
# post_max_size / upload_max_filesize to at least these values (see deploy/nginx-upload-limits.conf.example).
# DOC_UPLOAD_MAX_TOTAL_MB=2048
# DOC_UPLOAD_MAX_FILE_MB=1024
# Files larger than this (MB) use chunked upload (POST to Laravel) when FILESYSTEM_DISK=s3 (avoids Laravel Cloud ~100MB single POST).
# DOC_DIRECT_UPLOAD_MIN_MB=75
# Chunk size in bytes for large uploads. Must be at least 5242880 (5 MiB) for S3/R2 multipart rules. Each chunk is a POST to Laravel; parts are UploadPart then CompleteMultipartUpload (no full-file merge on the app server).
# DOC_UPLOAD_CHUNK_BYTES=5242880
# R2: presigned PUT for smaller files in the same batch may still need CORS for PUT from your app origin.

# In-browser document editing (OnlyOffice Document Server)
# ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8082
# When OnlyOffice runs in Docker locally, use host.docker.internal so the container can reach Laravel:
# ONLYOFFICE_APP_URL=http://host.docker.internal:17500
# Production: set both to your public HTTPS URLs (ONLYOFFICE_APP_URL usually matches APP_URL).
